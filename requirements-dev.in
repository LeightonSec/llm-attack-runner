# Development/CI dependencies, layered on top of the compiled runtime lockfile.
# Referencing requirements.txt (the compiled runtime lockfile) — NOT
# requirements.in — keeps the shared runtime pins identical between the two.
# Compile with: uv pip compile requirements-dev.in -o requirements-dev.txt \
#   --universal --generate-hashes --python-version 3.10
-r requirements.txt
pytest
ruff
